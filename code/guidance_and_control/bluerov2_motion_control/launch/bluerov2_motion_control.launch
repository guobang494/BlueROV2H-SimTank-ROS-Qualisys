<launch>
  <!-- Optional: start the _meas source together with control+filter. -->
  <arg name="start_qualisys_trans" default="true"/>
  <arg name="child_frame_id" default="BlueROV2H"/>
  <arg name="frame_id" default="mocap"/>
  <arg name="publish_rate" default="20.0"/>
  <arg name="pose_topic" default="/bluerov2_heavy"/>

  <include if="$(arg start_qualisys_trans)"
           file="$(find mavros_pub)/launch/qualisys_trans.launch">
    <arg name="child_frame_id" value="$(arg child_frame_id)"/>
    <arg name="frame_id" value="$(arg frame_id)"/>
    <arg name="publish_rate" value="$(arg publish_rate)"/>
    <arg name="pose_topic" value="$(arg pose_topic)"/>
  </include>

  <group ns="bluerov2_motion_control">

    <node name="qualisys_filter_node"
    pkg="bluerov2_motion_control"
    type="qualisys_filter_node.py"
    output="screen">
    <rosparam command="load"
    file="$(find bluerov2_motion_control)/configs/bluerov2_motion_control_config.yaml" />
    <param name="pose_topic" value="/bluerov2_heavy" />
    </node>

    <node name="bluerov2_motion_control_position_node" 
    pkg="bluerov2_motion_control" 
    type="bluerov2_motion_control_position_node" 
    output="screen">
    <rosparam command="load" 
    file="$(find bluerov2_motion_control)/configs/bluerov2_motion_control_config.yaml" />
    </node>
    
    <node name="bluerov2_motion_control_velocity_node" 
    pkg="bluerov2_motion_control" 
    type="bluerov2_motion_control_velocity_node" 
    output="screen">
    <rosparam command="load" 
    file="$(find bluerov2_motion_control)/configs/bluerov2_motion_control_config.yaml" />
    </node>
    
  </group>
</launch>
